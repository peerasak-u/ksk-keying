# Copy to .env (gitignored) and fill in real keys.
#   set -a && source .env && set +a
#
# ksk-keying itself (coa-to-csv, review-groups) does NOT need these — they are
# deterministic. Keys are only used by the legacy pipeline tools (gate/extract/
# categorize) if you run them.

GEMINI_API_KEY=
OPENROUTER_API_KEY=
