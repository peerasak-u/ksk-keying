# Copy to .env (gitignored) and fill in for a real run. Blank/unset vars
# fall back to mock mode — see docker-compose.yml and README.md.

# UID=1000
# GID=1000
# HOST_HOME=/home/peerasak
# ^ required for the credential mounts below — set explicitly rather than
#   relying on shell $HOME, which resolves to /root under `sudo docker ...`

# KSK_ENGINE=claude
# KSK_WORKSPACE_ROOT_HOST=/home/peerasak/Dropbox/สารบัญงานบัญชี_For Ton/samples/clients
# KSK_SKILLS_HOST=/home/peerasak/Dropbox/สารบัญงานบัญชี_For Ton/.claude
# ^ required whenever KSK_ENGINE=claude: the repo/install root's .claude/
#   (skills + agents) — without it /ksk-keying is genuinely unknown to the
#   CLI inside the container and every run no-ops instantly, misreported as
#   a clean "done". Point it at whichever .claude/ actually owns the
#   /ksk-keying skill for the workspace above (the dev repo's own .claude/
#   for samples/clients, or the Dropbox install's .claude/ for a real
#   client workspace — see the root CLAUDE.md's two deployment copies).
# KSK_PERMISSION_MODE=bypassPermissions
# KSK_ENGINE_MODEL=opus
# KSK_MAX_BUDGET_USD=15
# KSK_RUN_BUDGET_USD=25
